# ── Database ──────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/jaipur_travel?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kolkata
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ── JWT Secrets (use long random strings in production) ──
JWT_ACCESS_SECRET=changeThisToALongRandomAccessSecretKey2024!
JWT_REFRESH_SECRET=changeThisToALongRandomRefreshSecretKey2024!

# ── Token Expiration (milliseconds) ──────────────────────
# Access token: 15 minutes
JWT_ACCESS_EXPIRATION=900000
# Refresh token: 7 days
JWT_REFRESH_EXPIRATION=604800000

# ── Frontend URL (for CORS) ──────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Phase 2+ (not needed yet) ────────────────────────────
# HF_CHAT_API_KEY=
# WEATHER_API_KEY=
